PORT=4345
NODE_ENV=production

# PostgreSQL (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT
JWT_SECRET=generate-a-random-secret-here
JWT_REFRESH_SECRET=generate-another-random-secret-here
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Frontend URL (for CORS + password reset links)
FRONTEND_URL=https://your-frontend.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=dtqhdqoob
CLOUDINARY_API_KEY=668842416636121
CLOUDINARY_API_SECRET=your-api-secret

# SMTP (for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@zenith.com

# Upstash Redis
REDIS_URL=your-upstash-redis-rest-url
